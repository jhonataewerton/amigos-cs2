APP_PORT=3000
ALLOWED_ORIGIN=https://amigos-cs2-north-wind.web.app
GAMERSCLUB_BASE_URL=https://gamersclub.com.br
GCID_BASE_URL=https://gcid.gamersclub.gg

# ── Modo de autenticação ──────────────────────────────────────────────────────
# "manual" → usa cookies copiados do browser (mais simples para começar)
# "auto"   → Puppeteer faz login automaticamente
GC_AUTH_MODE=manual

# ── Modo MANUAL: cookies copiados do DevTools ─────────────────────────────────
# Chrome → gamersclub.com.br → F12 → Application → Cookies → gamersclub.com.br
GC_COOKIE_GCLUBSESS=
GC_COOKIE_ACCESS_TOKEN=
GC_COOKIE_CF_CLEARANCE=

# ── Modo AUTO: credenciais para login via Puppeteer ───────────────────────────
GC_EMAIL=seu-email@exemplo.com
GC_PASSWORD=sua-senha

# Arquivo para persistir a sessão entre restarts
SESSION_FILE=.session.json

# Chave para proteger as rotas /api/session/* em produção (opcional em dev)
INTERNAL_API_KEY=

# Puppeteer / Cloudflare
PUPPETEER_HEADLESS=true        # false para depurar o browser visualmente
CF_CRON=*/25 * * * *           # intervalo de renovação do cf_clearance

# Tempo de validade da sessão em horas antes de refazer login completo
SESSION_TTL_HOURS=6
